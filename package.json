{
  "name": "float-finder",
  "version": "1.0.0",
  "description": "Float Finder - Textile float detection tool for Jacquard/embroidery design",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder --win --x64",
    "dist:portable": "electron-builder --win portable --x64",
    "dist:installer": "electron-builder --win nsis --x64"
  },
  "keywords": ["textile", "jacquard", "float-finder", "weaving"],
  "author": "Balaji and Brother",
  "license": "ISC",
  "devDependencies": {
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.balajiandbros.floatfinder",
    "productName": "Float Finder",
    "copyright": "Copyright © 2026 Balaji and Brother",
    "directories": {
      "output": "release",
      "buildResources": "assets"
    },
    "files": [
      "FloatFinder.html",
      "License.html",
      "main.js",
      "preload.js",
      "assets/**",
      "!assets/README.txt",
      "!node_modules/**",
      "!release/**",
      "!.git/**"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        },
        {
          "target": "portable",
          "arch": ["x64"]
        }
      ],
      "icon": "assets/icon.ico",
      "requestedExecutionLevel": "asInvoker"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Float Finder",
      "installerIcon": "assets/icon.ico",
      "uninstallerIcon": "assets/icon.ico",
      "deleteAppDataOnUninstall": true
    },
    "portable": {
      "artifactName": "Float-Finder-Portable-${version}.exe"
    },
    "artifactName": "Float-Finder-Setup-${version}.exe"
  }
}
